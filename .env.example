# ──────────────────────────────────────────────────────────────────
# ScanAI — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

# Google Gemini API Key (REQUIRED for AI report generation)
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Models
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql://scanai:scanai@db:5432/scanai

# Redis (defaults work with docker-compose)
REDIS_URL=redis://redis:6379/0

# BullMQ scheduler internal API token (set the same value on api/worker/scheduler)
SCHEDULER_TOKEN=change-this-scheduler-token-in-production

# SMTP report delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=reports@example.com
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM="ScanAI Reports <reports@example.com>"
SMTP_SECURE=false
EMAIL_RATE_LIMIT_MAX=10
EMAIL_RATE_LIMIT_DURATION_MS=60000
EMAIL_CONCURRENCY=1
ACCOUNT_OTP_TTL_MINUTES=10
ACCOUNT_OTP_MAX_ATTEMPTS=5
IP_TIMEZONE_LOOKUP_ENABLED=true
IP_TIMEZONE_LOOKUP_TIMEOUT_SECONDS=2

# Application Secret Key (change in production)
SECRET_KEY=change-me-to-a-random-string-in-production

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# App URLs used by the separated Next.js apps
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3001

# Google OAuth sign-in
# Create a Google OAuth web client and add this redirect URI:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Optional: restrict Google sign-in to a Google Workspace / Cloud Identity domain.
GOOGLE_ALLOWED_DOMAIN=

# Rate Limiting — max active scans per IP
MAX_SCANS_PER_IP=1
PAID_BETA_MODE=true
REQUIRE_TARGET_VERIFICATION=true
BETA_MONTHLY_SCAN_LIMIT=25
BETA_ACTIVE_SCAN_LIMIT=1
BETA_SCHEDULE_LIMIT=3

# Scan Timeout — seconds before a scan is killed (default: 8 minutes)
SCAN_TIMEOUT_SECONDS=480

# Individual Tool Timeout — seconds per scanner tool (default: 2 minutes)
TOOL_TIMEOUT_SECONDS=120
TLS_DEEP_SCAN_ENABLED=true
TLS_DEEP_SCAN_TIMEOUT_SECONDS=45
SCAN_QUEUE_BACKEND=bullmq
SCAN_PIPELINE_PARALLELISM=4
SCAN_DISPATCH_SYNC_INTERVAL_MS=3000
SCAN_DISPATCH_CONCURRENCY=2
SCAN_DISPATCH_RATE_LIMIT_MAX=4
SCAN_DISPATCH_RATE_LIMIT_DURATION_MS=60000

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# Set to .welocalhost.com in production-like two-subdomain setups so
# scanai.welocalhost.com login also authenticates admin.scanai.welocalhost.com.
AUTH_COOKIE_DOMAIN=

# Temp directory for scan output files
SCAN_OUTPUT_DIR=/tmp/scanai

# HTML-to-PDF rendering
PDF_BROWSER_BIN=
PDF_RENDER_TIMEOUT_SECONDS=20
