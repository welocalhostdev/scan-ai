{
  "name": "scanai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@scanai/web",
    "dev:admin": "turbo run dev --filter=@scanai/admin",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@scanai/web",
    "build:admin": "turbo run build --filter=@scanai/admin",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.6.3"
  }
}
